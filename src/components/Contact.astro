---
---
<section id="contact" class="relative grain px-8 md:px-16 py-20" style="background: linear-gradient(135deg, #101357 0%, #1a1f6e 100%); overflow:hidden;">
  <!-- decorative background circles -->
  <div class="absolute pointer-events-none" style="width:500px;height:500px;border-radius:50%;background:rgba(254,164,159,0.08);top:-150px;right:-100px;"></div>
  <div class="absolute pointer-events-none" style="width:300px;height:300px;border-radius:50%;background:rgba(68,164,242,0.07);bottom:-80px;left:-50px;"></div>

  <div class="relative z-10 max-w-2xl mx-auto">
    <div class="mb-10">
      <div class="np-label"><span>Contact</span></div>
      <h2 style="font-family:'Pacifico',cursive; font-size:clamp(2rem,5vw,3.2rem); color:#FEF8EA; line-height:1.15;">
        Let's Make Something
      </h2>
      <p style="font-family:'Roboto Condensed',sans-serif; font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; color:rgba(254,248,234,0.5); margin-top:0.5rem;">
        Licensing inquiries · Cover requests · Film &amp; TV sync
      </p>
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      style="display:flex; flex-direction:column; gap:1.2rem;"
    >
      <input type="hidden" name="form-name" value="contact" />

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.2rem;">
        <div>
          <label style="font-family:'Roboto Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(254,248,234,0.6); display:block; margin-bottom:6px;">Name</label>
          <input
            type="text"
            name="name"
            required
            style="width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(254,248,234,0.2); color:#FEF8EA; padding:12px 14px; font-family:'IM Fell English',Georgia,serif; font-size:0.95rem; outline:none; box-sizing:border-box; transition:border-color .2s;"
            onfocus="this.style.borderColor='#fea49f'"
            onblur="this.style.borderColor='rgba(254,248,234,0.2)'"
          />
        </div>
        <div>
          <label style="font-family:'Roboto Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(254,248,234,0.6); display:block; margin-bottom:6px;">Email</label>
          <input
            type="email"
            name="email"
            required
            style="width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(254,248,234,0.2); color:#FEF8EA; padding:12px 14px; font-family:'IM Fell English',Georgia,serif; font-size:0.95rem; outline:none; box-sizing:border-box; transition:border-color .2s;"
            onfocus="this.style.borderColor='#fea49f'"
            onblur="this.style.borderColor='rgba(254,248,234,0.2)'"
          />
        </div>
      </div>

      <div>
        <label style="font-family:'Roboto Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(254,248,234,0.6); display:block; margin-bottom:6px;">Subject</label>
        <input
          type="text"
          name="subject"
          style="width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(254,248,234,0.2); color:#FEF8EA; padding:12px 14px; font-family:'IM Fell English',Georgia,serif; font-size:0.95rem; outline:none; box-sizing:border-box; transition:border-color .2s;"
          onfocus="this.style.borderColor='#fea49f'"
          onblur="this.style.borderColor='rgba(254,248,234,0.2)'"
        />
      </div>

      <div>
        <label style="font-family:'Roboto Condensed',sans-serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(254,248,234,0.6); display:block; margin-bottom:6px;">Message</label>
        <textarea
          name="message"
          rows="5"
          required
          style="width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(254,248,234,0.2); color:#FEF8EA; padding:12px 14px; font-family:'IM Fell English',Georgia,serif; font-size:0.95rem; outline:none; box-sizing:border-box; resize:none; transition:border-color .2s;"
          onfocus="this.style.borderColor='#fea49f'"
          onblur="this.style.borderColor='rgba(254,248,234,0.2)'"
        ></textarea>
      </div>

      <button
        type="submit"
        style="align-self:flex-start; background:#fea49f; color:#fff; font-family:'Roboto Condensed',sans-serif; font-size:0.78rem; letter-spacing:0.25em; text-transform:uppercase; padding:14px 40px; border:2px dashed #FFE940; cursor:pointer; transition:background .2s;"
        onmouseover="this.style.background='#f04a53'"
        onmouseout="this.style.background='#fea49f'"
      >
        Send Message
      </button>
    </form>
  </div>
</section>
