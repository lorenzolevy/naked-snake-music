---
---
<style>
  .hero {
    background-position: center 20%;
  }
  @media (max-width: 768px) {
    .hero {
      background-position: 35% 20%;
      background-image: url('/heroOriginal.jpg') !important;
      background-attachment: scroll;
    }
  }
</style>
<section
  class="hero relative flex items-center justify-end min-h-[55vh] px-8 md:px-20 py-24"
  style="background-image:url('/hero.png'); background-size:cover; background-attachment:fixed;"
>
  <!-- layered overlay: dark + warm tint -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(254,164,159,0.25) 0%, rgba(0,0,0,0.55) 100%)"></div>

  <!-- decorative dashed border frame (inset) -->
  <div class="absolute inset-3 md:inset-6 pointer-events-none" style="border: 2px dashed rgba(255,233,64,0.4); border-radius: 2px;"></div>

  <div class="relative z-10 text-right max-w-xl">
    <p class="fade-up fade-up-1 mb-3" style="font-family:'Roboto Condensed',sans-serif; font-size:0.75rem; letter-spacing:0.3em; text-transform:uppercase; color:#FFE940;">
      Works Written &amp; Co-Written by
    </p>
    <h1 class="fade-up fade-up-2 leading-tight mb-5" style="font-family:'Pacifico',cursive; font-size:clamp(2.8rem,7vw,5.5rem); color:#fff; text-shadow: 3px 4px 12px rgba(0,0,0,0.5);">
      Naked Snake<br/>Music
    </h1>
    <p class="fade-up fade-up-3 mb-10" style="font-size:1.1rem; color:rgba(255,255,255,0.88); line-height:1.6; text-shadow:1px 1px 4px #000;">
      a lifetime's worth of<br/>Lowell George's songwriting
    </p>
    <a
      href="#contact"
      class="fade-up fade-up-4 inline-block"
      style="background:#f04a53; color:#fff; font-family:'Roboto Condensed',sans-serif; font-size:0.78rem; letter-spacing:0.25em; text-transform:uppercase; padding:14px 36px; text-decoration:none; border:2px dashed #FFE940; transition:background .2s;"
      onmouseover="this.style.background='#fea49f'"
      onmouseout="this.style.background='#f04a53'"
    >
      Contact Us
    </a>
  </div>
</section>
